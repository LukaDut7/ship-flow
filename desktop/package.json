{
  "name": "@shipflow/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Ship Flow desktop app",
  "author": {
    "name": "Ship Flow",
    "email": "support@shipflow.dev"
  },
  "homepage": "https://shipflow.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/shipflow/desktop.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc && npm run copy-renderer && electron .",
    "build": "tsc && npm run copy-renderer",
    "copy-renderer": "node -e \"const fs=require('fs'),p=require('path');const s='src/renderer',d='dist/renderer';fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)))\"",
    "prepare-runtime": "node ../scripts/prepare-desktop-runtime.mjs",
    "package": "npm run prepare-runtime && electron-builder",
    "package:mac": "npm run prepare-runtime && electron-builder --mac",
    "package:win": "npm run prepare-runtime && electron-builder --win",
    "package:linux": "npm run prepare-runtime && electron-builder --linux",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "extends": "./electron-builder.yml"
  },
  "devDependencies": {
    "@types/ssh2": "^1.15.0",
    "electron": "35.7.5",
    "electron-builder": "^26.0.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@shipflow/shared": "*",
    "electron-updater": "^6.6.2",
    "ssh2": "^1.16.0"
  }
}
